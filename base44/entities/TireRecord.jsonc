{
  "name": "TireRecord",
  "type": "object",
  "properties": {
    "vehicle_id": {
      "type": "string"
    },
    "brand": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "size": {
      "type": "string"
    },
    "seasonal_type": {
      "type": "string",
      "enum": [
        "summer",
        "winter",
        "all_season"
      ]
    },
    "installation_date": {
      "type": "string",
      "format": "date"
    },
    "mileage_at_installation": {
      "type": "number"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "installation",
        "rotation",
        "repair",
        "replacement"
      ]
    },
    "notes": {
      "type": "string"
    },
    "cost": {
      "type": "number"
    },
    "front_tire_date": {
      "type": "string",
      "description": "Front tire manufacturing date (MM/YY)"
    },
    "back_tire_date": {
      "type": "string",
      "description": "Back tire manufacturing date (MM/YY)"
    },
    "front_tire_expiry": {
      "type": "string",
      "format": "date",
      "description": "Front tire expiration date"
    },
    "back_tire_expiry": {
      "type": "string",
      "format": "date",
      "description": "Back tire expiration date"
    }
  },
  "required": [
    "vehicle_id",
    "action_type"
  ]
}